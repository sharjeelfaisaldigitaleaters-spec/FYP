# Copy this file to .env locally and fill in real values.
# In production (Render, etc.) set these as environment variables in the
# hosting dashboard instead of committing a .env file.

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Comma-separated list of frontend origins allowed to call this API.
# Include your Vercel production URL (and any preview URLs) here.
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# Supabase Configuration
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET_NAME=memories-gallery

# API Keys
GROQ_API_KEY=
ELEVENLABS_API_KEY=

# JWT Secret Key (for validation) — generate a long random string
JWT_SECRET=
